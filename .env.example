# === Application ===
APP_NAME=PalmTreeDB
APP_VERSION=0.1.0
DEBUG=true

# === Database (PostgreSQL) ===
POSTGRES_USER=palmtreedb
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=palmtreedb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Constructed internally by pydantic-settings:
# DATABASE_URL=postgresql+psycopg://palmtreedb:<password>@localhost:5432/palmtreedb

# === pgAdmin ===
PGADMIN_DEFAULT_EMAIL=admin@palmtreedb.dev
PGADMIN_DEFAULT_PASSWORD=your-pgadmin-password-here

# === CORS ===
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# === JWT ===
JWT_SECRET_KEY=your-jwt-secret-here-use-secrets-token-urlsafe-48
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === Encryption (Fernet) ===
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here-generate-with-command-above

# === Registration ===
REGISTRATION_ENABLED=false