# === Application ===
APP_NAME=DBaaS Platform
APP_VERSION=0.1.0
DEBUG=true

# === Database (PostgreSQL) ===
POSTGRES_USER=dbaas
POSTGRES_PASSWORD=dbaas_secret
POSTGRES_DB=dbaas
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Constructed internally by pydantic-settings:
# DATABASE_URL=postgresql+psycopg://dbaas:dbaas_secret@localhost:5432/dbaas

# === pgAdmin ===
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# === CORS ===
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# === JWT ===
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7